# Travel Agent environment variables
# Model provider — MiniMax (Mastra model router: 'minimax/MiniMax-M2')
MINIMAX_API_KEY=

# SerpApi (Google Flights) — real FLIGHT search
# Free key (no card, 250 searches/mo): https://serpapi.com
SERPAPI_KEY=

# LiteAPI — real HOTEL search + live rates
# Free instant key: https://liteapi.travel (sandbox keys start with "sand_")
LITE_API_KEY=

# Added in later phases:
# MASTRA_JWT_SECRET=        # Phase 9 — auth (any HS256-safe secret)
# MASTRA_JWT_TOKEN=         # Phase 9 — dev client token
# LANGFUSE_PUBLIC_KEY=      # Phase 8 — optional observability
# LANGFUSE_SECRET_KEY=
# CLOUDFLARE_API_TOKEN=     # Phase 10 — optional deploy
